---
import BaseLayout from "../layouts/BaseLayout.astro";

export const prerender = true;
---

<BaseLayout title="Tanya CV AI" sideBarActiveItemID="tanyaCv">
  <section class="w-full max-w-3xl mx-auto space-y-6">
    <div class="space-y-2">
      <p class="text-sm font-semibold uppercase tracking-wide text-blue-700">AI CV</p>
      <h1 class="text-4xl font-bold text-gray-900">Tanya CV Reza</h1>
    </div>

    <div class="bg-white border border-gray-200 rounded-2xl shadow-sm overflow-hidden">
      <div id="messages" class="min-h-[320px] max-h-[520px] overflow-y-auto p-5 space-y-4 bg-gray-50">
        <article class="max-w-[88%] rounded-2xl rounded-tl-sm bg-white border border-gray-200 p-4 text-gray-700 shadow-sm">
          <p class="whitespace-pre-wrap leading-relaxed">
            Halo, saya bisa menjawab pertanyaan berdasarkan data CV Reza yang ada di website ini.
          </p>
        </article>
      </div>

      <form id="cvQuestionForm" class="p-4 space-y-4 border-t border-gray-200 bg-white">
        <div class="flex flex-wrap gap-2">
          <button type="button" data-question="Apa skill utama Reza?" class="px-3 py-2 text-sm rounded-full bg-blue-50 text-blue-700 hover:bg-blue-100 transition">Skill utama</button>
          <button type="button" data-question="Reza cocok untuk posisi apa?" class="px-3 py-2 text-sm rounded-full bg-blue-50 text-blue-700 hover:bg-blue-100 transition">Role cocok</button>
          <button type="button" data-question="Pengalaman backend Reza apa saja?" class="px-3 py-2 text-sm rounded-full bg-blue-50 text-blue-700 hover:bg-blue-100 transition">Backend</button>
        </div>

        <div class="flex gap-3">
          <input
            id="question"
            name="question"
            type="text"
            required
            maxlength="700"
            autocomplete="off"
            placeholder="Tulis pertanyaan tentang CV..."
            class="flex-1 min-w-0 rounded-xl border border-gray-300 px-4 py-3 text-gray-800 focus:border-blue-500 focus:outline-none focus:ring-2 focus:ring-blue-100"
          />
          <input type="text" name="bot-field" class="hidden" tabindex="-1" autocomplete="off" />
          <button
            type="submit"
            class="shrink-0 rounded-xl bg-blue-600 px-5 py-3 font-semibold text-white shadow-sm hover:bg-blue-700 disabled:cursor-not-allowed disabled:bg-gray-400 transition"
          >
            Kirim
          </button>
        </div>
      </form>
    </div>
  </section>

  <script>
    const form = document.getElementById("cvQuestionForm");
    const messages = document.getElementById("messages");
    const questionInput = document.getElementById("question");
    const submitButton = form?.querySelector('button[type="submit"]');
    const quickButtons = document.querySelectorAll("[data-question]");

    function appendMessage(text, type) {
      if (!messages) return null;

      const article = document.createElement("article");
      const isUser = type === "user";
      article.className = isUser
        ? "ml-auto max-w-[88%] rounded-2xl rounded-tr-sm bg-blue-600 p-4 text-white shadow-sm"
        : "max-w-[88%] rounded-2xl rounded-tl-sm bg-white border border-gray-200 p-4 text-gray-700 shadow-sm";

      const paragraph = document.createElement("p");
      paragraph.className = "whitespace-pre-wrap leading-relaxed";
      paragraph.textContent = text;
      article.appendChild(paragraph);
      messages.appendChild(article);
      messages.scrollTop = messages.scrollHeight;

      return paragraph;
    }

    function setLoading(isLoading) {
      if (submitButton instanceof HTMLButtonElement) {
        submitButton.disabled = isLoading;
        submitButton.textContent = isLoading ? "Menjawab..." : "Kirim";
      }
    }

    quickButtons.forEach((button) => {
      button.addEventListener("click", () => {
        if (questionInput instanceof HTMLInputElement) {
          questionInput.value = button.getAttribute("data-question") || "";
          questionInput.focus();
        }
      });
    });

    if (form instanceof HTMLFormElement && questionInput instanceof HTMLInputElement) {
      form.addEventListener("submit", async (event) => {
        event.preventDefault();

        const question = questionInput.value.trim();
        if (!question) return;

        appendMessage(question, "user");
        const loadingMessage = appendMessage("Sedang membaca data CV...", "ai");
        setLoading(true);

        const formData = new FormData(form);
        formData.set("question", question);

        try {
          const response = await fetch("/api/tanya-cv", {
            method: "POST",
            body: formData,
          });
          const data = await response.json();

          if (!response.ok) {
            if (loadingMessage) {
              loadingMessage.textContent = data.error || "Gagal mendapatkan jawaban.";
            }
            return;
          }

          if (loadingMessage) {
            loadingMessage.textContent = data.answer || "Tidak ada jawaban dari AI.";
          }
          questionInput.value = "";
        } catch (error) {
          console.error(error);
          if (loadingMessage) {
            loadingMessage.textContent = "Terjadi kesalahan saat menghubungi server.";
          }
        } finally {
          setLoading(false);
        }
      });
    }
  </script>
</BaseLayout>
