---
import SideBarFooter from "./SideBarFooter.astro";
import { Image } from "astro:assets";
import SideBarMenu from "./SideBarMenu.astro";
const { sideBarActiveItemID } = Astro.props;
---

<script is:inline>
  document.addEventListener("alpine:init", () => {
    Alpine.store("profile", { showModal: false });
  });
</script>

<div class="drawer-side z-40" x-data>
  <label for="my-drawer" class="drawer-overlay"></label>

  <aside
    class="h-full min-h-screen w-72 overflow-hidden border-r border-gray-200 bg-white text-gray-900 shadow-xl lg:rounded-r-2xl flex flex-col"
  >
    <div class="border-b border-gray-100 px-5 py-6">
      <button
        type="button"
        class="group mx-auto block rounded-full focus:outline-none focus:ring-4 focus:ring-blue-100"
        title="Klik untuk perbesar foto"
        @click="$store.profile.showModal = true"
      >
        <span class="block rounded-full bg-gradient-to-br from-blue-100 to-gray-100 p-1 transition group-hover:scale-[1.03]">
          <span class="block h-28 w-28 overflow-hidden rounded-full ring-4 ring-white">
            <Image
              class="h-full w-full object-cover"
              format="webp"
              width={300}
              height={300}
              src="/zaputlah.jpeg"
              alt="Profile image"
            />
          </span>
        </span>
      </button>

      <div class="mt-4 text-center">
        <a href="/" class="text-lg font-bold leading-tight hover:text-blue-700">
          Reza Putra Fadilah
        </a>
        <p class="mt-1 text-sm text-gray-500">Fullstack Developer</p>
      </div>

      <div class="mt-4 grid grid-cols-2 gap-2">
        <a
          class="inline-flex items-center justify-center gap-2 rounded-xl bg-gray-900 px-3 py-2 text-xs font-semibold text-white transition hover:bg-gray-700"
          href="/pdf/Reza_putra_fadilah_FlowCV_Resume_2026-05-02.pdf"
          download
        >
          <i class="fa-solid fa-file-arrow-down"></i>
          CV
        </a>
        <a
          class="inline-flex items-center justify-center gap-2 rounded-xl border border-gray-200 px-3 py-2 text-xs font-semibold text-gray-700 transition hover:border-blue-200 hover:bg-blue-50 hover:text-blue-700"
          href="mailto:reza.rr889@gmail.com"
        >
          <i class="fa-solid fa-envelope"></i>
          Email
        </a>
      </div>
    </div>

    <SideBarMenu sideBarActiveItemID={sideBarActiveItemID} />
    <SideBarFooter />
  </aside>

  <template x-if="$store.profile.showModal">
    <div
      class="fixed inset-0 flex items-center justify-center bg-black/70 z-50"
      @click.self="$store.profile.showModal = false"
    >
      <div class="relative bg-white p-4 rounded-2xl shadow-lg">
        <button
          type="button"
          class="absolute right-3 top-3 grid h-9 w-9 place-items-center rounded-full bg-white text-gray-600 shadow hover:text-gray-900"
          @click="$store.profile.showModal = false"
          aria-label="Tutup foto profil"
        >
          <i class="fa-solid fa-xmark"></i>
        </button>
        <img
          src="/zaputlah.jpeg"
          alt="Foto Profil"
          class="max-w-[90vw] max-h-[85vh] rounded-xl shadow-md"
        />
      </div>
    </div>
  </template>
</div>
